{
  "name": "@arifzyn/api",
  "version": "1.0.3",
  "description": "Simple API Wrapper For Arifzyn API",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "types": "./dist/@types/index.d.ts",
      "require": "./dist/cjs/index.js"
    }
  },
  "types": "./dist/@types/index.d.ts",
  "main": "./dist/cjs/index.js",
  "files": [
    "dist/"
  ],
  "scripts": {
    "clean": "rimraf ./dist",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "build:all": "npm run clean && npm run build:esm && npm run build:cjs && npm run build:types"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arifzyn19/AR-WRAPPER.git"
  },
  "keywords": [
    "api",
    "api-wrapper",
    "arifzyn",
    "arifzyn-api",
    "ar-api"
  ],
  "author": "Arifzyn19",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Arifzyn19/AR-WRAPPER/issues"
  },
  "homepage": "https://github.com/Arifzyn19/AR-WRAPPER",
  "dependencies": {
    "axios": "^1.1.3"
  },
  "devDependencies": {
    "rimraf": "^4.1.2",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.4"
  }
}
